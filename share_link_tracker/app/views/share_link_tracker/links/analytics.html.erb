<!-- app/views/share_link_tracker/links/analytics.html.erb -->
<h1>Link Analytics</h1>

<div class="link-info">
  <p><strong>Original URL:</strong> <%= @link.original_url %></p>
  <p><strong>Short URL:</strong> <%= link_to request.base_url + share_link_tracker.link_path(@link.short_url), 
              share_link_tracker.link_path(@link.short_url), 
              target: "_blank" %></p>
  <p><strong>Total Clicks:</strong> <%= @link.clicks_count %></p>
</div>

<div class="analytics-section">
  <h2>Device Types</h2>
  <% if @device_stats.any? %>
    <ul>
      <% @device_stats.each do |device_type, count| %>
        <li><%= device_type %>: <%= count %> visits</li>
      <% end %>
    </ul>
  <% else %>
    <p>No device data available yet.</p>
  <% end %>
</div>

<div class="analytics-section">
  <h2>Locations</h2>
  <% if @location_stats.any? %>
    <ul>
      <% @location_stats.each do |location, count| %>
        <li><%= location %>: <%= count %> visits</li>
      <% end %>
    </ul>
  <% else %>
    <p>No location data available yet.</p>
  <% end %>
</div>

<div class="analytics-section">
  <h2>Recent Visits</h2>
  <% if @recent_visits.any? %>
    <table>
      <thead>
        <tr>
          <th>Time</th>
          <th>Device</th>
          <th>IP Address</th>
          <th>Location</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_visits.each do |visit| %>
          <tr>
            <td><%= visit.visited_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
            <td><%= visit.device_type %></td>
            <td><%= visit.ip_address %></td>
            <td><%= visit.location %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No visit data available yet.</p>
  <% end %>
</div>

<div class="actions">
  <%= link_to "Back to Links", share_link_tracker.links_path, class: "btn" %>
  <%= link_to "View Infographic", share_link_tracker.infographic_link_path(@link.short_url), class: "btn" %>
</div> 