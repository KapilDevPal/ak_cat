<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header">
          <h4 class="mb-0">Enter Passcode</h4>
        </div>
        <div class="card-body">
          <%= form_tag profile_path(@profile), method: :get do %>
            <div class="mb-3">
              <%= label_tag :passcode, "Passcode", class: "form-label" %>
              <%= password_field_tag :passcode, nil, class: "form-control", placeholder: "Enter 4-digit passcode", required: true %>
            </div>
            <div class="d-grid">
              <%= submit_tag "View Profile", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div> 