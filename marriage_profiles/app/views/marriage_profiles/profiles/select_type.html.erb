<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h2 class="mb-0 text-center">What kind of profile do you want to create?</h2>
        </div>
        <div class="card-body p-4">
          <div class="row">
            <div class="col-md-4 mb-3">
              <div class="card h-100 profile-type-card" onclick="window.location='<%= new_profile_path(type: 'generic') %>'">
                <div class="card-body text-center">
                  <i class="fas fa-user-circle fa-4x mb-3 text-primary"></i>
                  <h3>Generic</h3>
                  <p class="text-muted">Personal sharing or casual use</p>
                </div>
                <div class="card-footer bg-white text-center border-top-0">
                  <a href="<%= new_profile_path(type: 'generic') %>" class="btn btn-outline-primary">Select</a>
                </div>
              </div>
            </div>
            
            <div class="col-md-4 mb-3">
              <div class="card h-100 profile-type-card" onclick="window.location='<%= new_profile_path(type: 'professional') %>'">
                <div class="card-body text-center">
                  <i class="fas fa-briefcase fa-4x mb-3 text-success"></i>
                  <h3>Professional</h3>
                  <p class="text-muted">Showcase work, skills, or business info</p>
                </div>
                <div class="card-footer bg-white text-center border-top-0">
                  <a href="<%= new_profile_path(type: 'professional') %>" class="btn btn-outline-success">Select</a>
                </div>
              </div>
            </div>
            
            <div class="col-md-4 mb-3">
              <div class="card h-100 profile-type-card" onclick="window.location='<%= new_profile_path(type: 'marriage') %>'">
                <div class="card-body text-center">
                  <i class="fas fa-heart fa-4x mb-3 text-danger"></i>
                  <h3>Marriage</h3>
                  <p class="text-muted">Tailored for matrimony and matchmaking</p>
                </div>
                <div class="card-footer bg-white text-center border-top-0">
                  <a href="<%= new_profile_path(type: 'marriage') %>" class="btn btn-outline-danger">Select</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="text-center mt-3">
        <a href="<%= profiles_path %>" class="btn btn-link">Back to profiles</a>
      </div>
    </div>
  </div>
</div>

<style>
  .profile-type-card {
    transition: transform 0.3s, box-shadow 0.3s;
    cursor: pointer;
  }
  
  .profile-type-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
</style> 