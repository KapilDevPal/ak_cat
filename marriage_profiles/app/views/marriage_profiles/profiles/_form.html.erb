<%= form_with(model: profile, local: true, html: { class: "needs-validation", multipart: true }) do |f| %>
  <% if profile.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h2><%= pluralize(profile.errors.count, "error") %> prohibited this profile from being saved:</h2>
      <ul>
        <% profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :profile_type %>

  <div class="card mb-4">
    <div class="card-header">
      <h4>Basic Information</h4>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= f.label :first_name, class: "form-label" %>
          <%= f.text_field :first_name, class: "form-control", required: true %>
        </div>
        <div class="col-md-6 mb-3">
          <%= f.label :last_name, class: "form-label" %>
          <%= f.text_field :last_name, class: "form-control", required: true %>
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :bio, class: "form-label" %>
        <%= f.text_area :bio, class: "form-control", rows: 5, required: true %>
        <div class="form-text">Minimum 50 characters, maximum 1000 characters</div>
      </div>

      <div class="mb-3">
        <%= f.check_box :passcode_enabled, class: "form-check-input" %>
        <%= f.label :passcode_enabled, "Enable Passcode Protection", class: "form-check-label" %>
      </div>

      <div class="mb-3" id="passcode_field" style="display: <%= profile.passcode_enabled? ? 'block' : 'none' %>">
        <%= f.label :passcode, class: "form-label" %>
        <%= f.password_field :passcode, class: "form-control", placeholder: "Enter 4-digit passcode" %>
      </div>
    </div>
  </div>

  <% if profile.profile_type == 'marriage' %>
    <div class="card mb-4">
      <div class="card-header">
        <h4>Marriage Profile Details</h4>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :date_of_birth, class: "form-label" %>
            <%= f.date_field :date_of_birth, class: "form-control", required: true %>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :gender, class: "form-label" %>
            <%= f.select :gender, MarriageProfiles::Profile.genders.keys.map { |g| [g.titleize, g] }, { include_blank: "Select Gender" }, { class: "form-select", required: true } %>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :religion, class: "form-label" %>
            <%= f.text_field :religion, class: "form-control", required: true %>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :caste, class: "form-label" %>
            <%= f.text_field :caste, class: "form-control" %>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :occupation, class: "form-label" %>
            <%= f.text_field :occupation, class: "form-control", required: true %>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :education, class: "form-label" %>
            <%= f.text_field :education, class: "form-control", required: true %>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :income, class: "form-label" %>
            <%= f.text_field :income, class: "form-control" %>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :height, class: "form-label" %>
            <%= f.text_field :height, class: "form-control", required: true %>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :location, class: "form-label" %>
            <%= f.text_field :location, class: "form-control", required: true %>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :marital_status, class: "form-label" %>
            <%= f.text_field :marital_status, class: "form-control", required: true %>
          </div>
        </div>

        <div class="mb-3">
          <%= f.label :family_details, class: "form-label" %>
          <%= f.text_area :family_details, class: "form-control", rows: 3 %>
        </div>

        <div class="mb-3">
          <%= f.label :preferences, class: "form-label" %>
          <%= f.text_area :preferences, class: "form-control", rows: 3 %>
        </div>
      </div>
    </div>
  <% elsif profile.profile_type == 'professional' %>
    <div class="card mb-4">
      <div class="card-header">
        <h4>Professional Profile Details</h4>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :title, class: "form-label" %>
            <%= f.text_field :title, class: "form-control", required: true %>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :company, class: "form-label" %>
            <%= f.text_field :company, class: "form-control" %>
          </div>
        </div>

        <div class="mb-3">
          <%= f.label :skills, class: "form-label" %>
          <%= f.text_area :skills, class: "form-control", rows: 3, required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :education, class: "form-label" %>
          <%= f.text_field :education, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :experience, class: "form-label" %>
          <%= f.text_area :experience, class: "form-control", rows: 3, required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :portfolio_links, class: "form-label" %>
          <%= f.text_area :portfolio_links, class: "form-control", rows: 2 %>
        </div>

        <div class="mb-3">
          <%= f.label :contact_email, class: "form-label" %>
          <%= f.email_field :contact_email, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :availability, class: "form-label" %>
          <%= f.text_field :availability, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :resume, class: "form-label" %>
          <%= f.file_field :resume, class: "form-control" %>
        </div>
      </div>
    </div>
  <% elsif profile.profile_type == 'generic' %>
    <div class="card mb-4">
      <div class="card-header">
        <h4>Generic Profile Details</h4>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <%= f.label :location, class: "form-label" %>
          <%= f.text_field :location, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :hobbies, class: "form-label" %>
          <%= f.text_area :hobbies, class: "form-control", rows: 3 %>
        </div>

        <div class="mb-3">
          <%= f.label :social_links, class: "form-label" %>
          <%= f.text_area :social_links, class: "form-control", rows: 2 %>
        </div>

        <div class="mb-3">
          <%= f.label :availability_status, class: "form-label" %>
          <%= f.text_field :availability_status, class: "form-control" %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="card mb-4">
    <div class="card-header">
      <h4>Profile Photos</h4>
    </div>
    <div class="card-body">
      <div class="mb-3">
        <%= f.label :cover_image, "Cover Image", class: "form-label" %>
        <%= f.file_field :cover_image, class: "form-control", accept: "image/*" %>
      </div>

      <div id="photos">
        <%= f.fields_for :photos do |photo| %>
          <%= render 'photo_fields', f: photo %>
        <% end %>
        <div class="links mb-3">
          <%= link_to_add_association 'Add Photo', f, :photos, class: 'btn btn-primary' %>
        </div>
      </div>
    </div>
  </div>

  <div class="mb-4 text-center">
    <%= f.submit class: "btn btn-success btn-lg" %>
    <%= link_to 'Cancel', profiles_path, class: "btn btn-secondary btn-lg ms-2" %>
  </div>
<% end %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const passcodeCheckbox = document.querySelector('#profile_passcode_enabled');
    const passcodeField = document.querySelector('#passcode_field');

    if (passcodeCheckbox) {
      passcodeCheckbox.addEventListener('change', function() {
        passcodeField.style.display = this.checked ? 'block' : 'none';
      });
    }
  });
</script> 