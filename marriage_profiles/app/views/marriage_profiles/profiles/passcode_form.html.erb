<div class="container">
  <div class="row justify-content-center mt-5">
    <div class="col-md-6">
      <div class="card shadow">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">Protected Profile</h4>
        </div>
        <div class="card-body">
          <p class="alert alert-info">
            This profile is protected with a passcode. Please enter the passcode to view it.
          </p>
          
          <% if flash[:alert] %>
            <div class="alert alert-danger"><%= flash[:alert] %></div>
          <% end %>
          
          <%= form_with(url: profile_path(@profile), method: :get, local: true) do |f| %>
            <div class="mb-3">
              <%= f.label :passcode, "Enter Passcode", class: "form-label" %>
              <%= f.password_field :passcode, class: "form-control", required: true, autocomplete: "off", placeholder: "Enter the 4-digit passcode" %>
            </div>
            
            <div class="d-grid gap-2">
              <%= f.submit "View Profile", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
          
          <div class="mt-3 text-center">
            <%= link_to "Back to Profiles", profiles_path, class: "text-decoration-none" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div> 