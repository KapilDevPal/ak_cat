<div class="alert alert-success">
  <i class="fas fa-info-circle me-2"></i>You are creating a <strong>Professional Profile</strong> to showcase your work, skills, or business info.
</div>

<div class="row">
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :first_name, class: "form-label" %>
      <%= f.text_field :first_name, class: "form-control", required: true %>
    </div>
  </div>
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :last_name, class: "form-label" %>
      <%= f.text_field :last_name, class: "form-control", required: true %>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :title, class: "form-label" %>
      <%= f.text_field :title, class: "form-control", required: true, placeholder: "e.g. Software Engineer" %>
    </div>
  </div>
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :company, class: "form-label" %>
      <%= f.text_field :company, class: "form-control", placeholder: "e.g. Acme Corp" %>
    </div>
  </div>
</div>

<div class="form-group mb-3">
  <%= f.label :bio, class: "form-label" %>
  <%= f.text_area :bio, class: "form-control", rows: 5, required: true %>
  <div class="form-text">Minimum 50 characters, maximum 1000 characters.</div>
</div>

<div class="form-group mb-3">
  <%= f.label :skills, class: "form-label" %>
  <%= f.text_area :skills, class: "form-control", rows: 3, required: true, placeholder: "e.g. JavaScript, React, Node.js, Project Management" %>
</div>

<div class="form-group mb-3">
  <%= f.label :experience, class: "form-label" %>
  <%= f.text_area :experience, class: "form-control", rows: 5, required: true %>
</div>

<div class="form-group mb-3">
  <%= f.label :education, class: "form-label" %>
  <%= f.text_field :education, class: "form-control", required: true %>
</div>

<div class="form-group mb-3">
  <%= f.label :location, class: "form-label" %>
  <%= f.text_field :location, class: "form-control" %>
</div>

<div class="form-group mb-3">
  <%= f.label :portfolio_links, class: "form-label" %>
  <%= f.text_area :portfolio_links, class: "form-control", rows: 3, placeholder: "Add links to your portfolio, LinkedIn, GitHub, etc." %>
</div>

<div class="form-group mb-3">
  <%= f.label :resume, class: "form-label" %>
  <%= f.file_field :resume, class: "form-control", accept: "application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" %>
  <% if profile.resume.present? %>
    <div class="mt-2">
      <p><i class="fas fa-file-alt me-2"></i><%= profile.resume.file.filename %></p>
    </div>
  <% end %>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :contact_email, class: "form-label" %>
      <%= f.email_field :contact_email, class: "form-control", required: true %>
    </div>
  </div>
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :availability, class: "form-label" %>
      <%= f.select :availability, ['Available Now', 'Available in 2 weeks', 'Available in 1 month', 'Not currently available'], 
            { include_blank: "Select Availability" }, class: "form-control" %>
    </div>
  </div>
</div> 