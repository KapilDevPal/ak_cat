<div class="alert alert-danger">
  <i class="fas fa-info-circle me-2"></i>You are creating a <strong>Marriage Profile</strong> tailored for matrimony and matchmaking.
</div>

<div class="row">
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :first_name, class: "form-label" %>
      <%= f.text_field :first_name, class: "form-control", required: true %>
    </div>
  </div>
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :last_name, class: "form-label" %>
      <%= f.text_field :last_name, class: "form-control", required: true %>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :date_of_birth, class: "form-label" %>
      <%= f.date_field :date_of_birth, 
          class: "form-control", 
          required: true,
          max: 18.years.ago.to_date,
          min: 100.years.ago.to_date %>
      <div class="form-text">Must be at least 18 years old</div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :gender, class: "form-label" %>
      <%= f.select :gender, MarriageProfiles::Profile.genders.keys.map { |g| [g.titleize, g] }, 
                { include_blank: "Select Gender" }, class: "form-control", required: true %>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :religion, class: "form-label" %>
      <%= f.text_field :religion, class: "form-control", required: true %>
    </div>
  </div>
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :caste, class: "form-label" %>
      <%= f.text_field :caste, class: "form-control" %>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :occupation, class: "form-label" %>
      <%= f.text_field :occupation, class: "form-control", required: true %>
    </div>
  </div>
  <div class="col-md-6">
    <div class="form-group mb-3">
      <%= f.label :education, class: "form-label" %>
      <%= f.text_field :education, class: "form-control", required: true %>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-4">
    <div class="form-group mb-3">
      <%= f.label :income, class: "form-label" %>
      <%= f.text_field :income, class: "form-control" %>
    </div>
  </div>
  <div class="col-md-4">
    <div class="form-group mb-3">
      <%= f.label :height, class: "form-label" %>
      <%= f.text_field :height, class: "form-control", required: true, placeholder: "e.g. 5'9\" or 175cm" %>
    </div>
  </div>
  <div class="col-md-4">
    <div class="form-group mb-3">
      <%= f.label :marital_status, class: "form-label" %>
      <%= f.select :marital_status, ['Single', 'Divorced', 'Widowed', 'Separated'], 
            { include_blank: "Select Status" }, class: "form-control", required: true %>
    </div>
  </div>
</div>

<div class="form-group mb-3">
  <%= f.label :location, class: "form-label" %>
  <%= f.text_field :location, class: "form-control", required: true %>
</div>

<div class="form-group mb-3">
  <%= f.label :bio, class: "form-label" %>
  <%= f.text_area :bio, class: "form-control", rows: 5, required: true %>
  <div class="form-text">Minimum 50 characters, maximum 1000 characters.</div>
</div>

<div class="form-group mb-3">
  <%= f.label :family_details, class: "form-label" %>
  <%= f.text_area :family_details, class: "form-control", rows: 3 %>
</div>

<div class="form-group mb-3">
  <%= f.label :preferences, class: "form-label" %>
  <%= f.text_area :preferences, class: "form-control", rows: 3, placeholder: "Describe what you're looking for in a partner" %>
</div> 