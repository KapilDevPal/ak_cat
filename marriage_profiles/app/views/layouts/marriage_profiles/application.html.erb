<!DOCTYPE html>
<html>
  <head>
    <title>Marriage Profiles</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "marriage_profiles/application", media: "all" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <style>
      .floating-action-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background-color: #ff4081;
        color: white;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        z-index: 1000;
        transition: all 0.3s;
        text-decoration: none;
        border: none;
      }
      
      .floating-action-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 12px rgba(0,0,0,0.3);
        color: white;
        text-decoration: none;
      }
      
      .tooltip-text {
        visibility: hidden;
        position: absolute;
        right: 70px;
        background-color: #333;
        color: white;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 14px;
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.3s;
      }
      
      .floating-action-btn:hover .tooltip-text {
        visibility: visible;
        opacity: 1;
      }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container">
        <%= link_to "Marriage Profiles", root_path, class: "navbar-brand" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
            <li class="nav-item">
              <%= link_to "All Profiles", profiles_path, class: "nav-link" %>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Browse Profiles
              </a>
              <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                <li><%= link_to "All Profiles", profiles_path, class: "dropdown-item" %></li>
                <li><hr class="dropdown-divider"></li>
                <li><%= link_to "Marriage Profiles", profiles_path(type: 'marriage'), class: "dropdown-item" %></li>
                <li><%= link_to "Professional Profiles", profiles_path(type: 'professional'), class: "dropdown-item" %></li>
                <li><%= link_to "Generic Profiles", profiles_path(type: 'generic'), class: "dropdown-item" %></li>
              </ul>
            </li>
            <li class="nav-item">
              <%= link_to "Create Profile", select_type_profiles_path, class: "nav-link" %>
            </li>
            <% if current_user %>
              <li class="nav-item">
                <%= link_to "My Profile", profiles_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= button_to "Sign Out", main_app.sign_out_path, method: :delete, class: "btn btn-link nav-link" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Sign In", main_app.sign_in_path, class: "nav-link" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>

      <%= yield %>
    </div>
    
    <!-- Floating Action Button -->
    <% if current_user %>
      <%= link_to select_type_profiles_path, class: "floating-action-btn" do %>
        <i class="fas fa-plus"></i>
        <span class="tooltip-text">Create New Profile</span>
      <% end %>
    <% else %>
      <%= link_to main_app.sign_up_path, class: "floating-action-btn" do %>
        <i class="fas fa-plus"></i>
        <span class="tooltip-text">Sign Up & Create Profile</span>
      <% end %>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
