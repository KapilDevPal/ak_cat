<div class="login">
  <h2>Admin Login</h2>

  <%= form_tag admin_user_session_path do %>
    <div class="form-group">
      <%= label_tag :email %>
      <%= email_field_tag :email, nil, class: 'form-control', autofocus: true %>
    </div>

    <div class="form-group">
      <%= label_tag :password %>
      <%= password_field_tag :password, nil, class: 'form-control' %>
    </div>

    <div class="actions">
      <%= submit_tag "Log in", class: 'button' %>
    </div>
  <% end %>

  <div style="margin-top: 20px; text-align: center;">
    <p>Use admin@example.com / password123</p>
  </div>
</div> 